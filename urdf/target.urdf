<robot name="purple_target">

  <!-- Material for the target -->
  <material name="purple">
    <color rgba="0.5 0.0 0.5 1.0"/> <!-- Purple color -->
  </material>

  <!-- Main link for the target -->
  <link name="target_base">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <inertia ixx="0.002" iyy="0.002" izz="0.002" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder length="0.2" radius="0.1"/>
      </geometry>
      <material name="purple"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.2" radius="0.1"/>
      </geometry>
    </collision>
  </link>

</robot>
